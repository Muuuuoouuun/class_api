academy:
  name: "Demo Academy"
  timezone: "Asia/Seoul"

classin:
  base_url: "https://api.eeo.cn"
  school_id: "REPLACE_ME"
  secret_key: "REPLACE_ME"
  webhook_secret: "REPLACE_ME"
  default_password: "Classin!2026"

storage:
  backend: "local"
  path: "./local_data/store.json"

output:
  daily:
    mode: "html"
    path: "./reports_out/daily"
    public_url_base: ""
  weekly:
    mode: "html"
    require_approval: true
    path: "./reports_out/weekly"
  memo:
    mode: "local"

anthropic:
  api_key: "REPLACE_ME"
  provider: "auto"
  model: "gemini-3.5-flash"
  report_model: "gemini-3.5-flash"

neis:
  api_key: "REPLACE_ME"
  base_url: "https://open.neis.go.kr/hub"
  schools: []
  event_keywords:
    - "시험"
    - "고사"
    - "학력평가"
    - "모의평가"
    - "모의고사"
    - "방학식"

notify:
  mode: "dry_run"
  provider: "aligo"
  aligo:
    api_key: "REPLACE_ME"
    user_id: "REPLACE_ME"
    sender: "01012345678"

webhook:
  host: "0.0.0.0"
  port: 8787
  dump_dir: "./samples/incoming"

reports:
  output_dir: "./reports_out"

course_links:
  aliases:
    "중2 수학 겨울방학 대비반":
      - "26 리얼 테스트"
