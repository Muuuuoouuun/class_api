academy:
  name: "○○수학학원"
  timezone: "Asia/Seoul"

classin:
  base_url: "https://api.eeo.cn"
  school_id: "REPLACE_ME"        # SID — eeo.cn 대시보드에서 확보
  secret_key: "REPLACE_ME"       # v2 서명 시크릿 (signing key)
  webhook_secret: "REPLACE_ME"   # Datasub SafeKey 검증용 공유비밀
  default_password: "Classin!2026"
  schedule_api: "lms"            # lms | legacy. 신규 연동은 LMS classroom 권장
  default_teacher_uid: ""        # teacher_uids 매칭 실패 시 사용할 기본 교사 UID (선택)
  lms_unit_prefix: "API 스케줄"
  teacher_uids:                  # 스케줄 CSV의 teacher 이름 → ClassIn 교사 UID
    "김선생": "REPLACE_ME_TEACHER_UID"

notion:
  token: "secret_REPLACE_ME"
  databases:
    students: "REPLACE_ME_STUDENTS_DB_ID"
    lessons: "REPLACE_ME_LESSONS_DB_ID"
    reports: "REPLACE_ME_REPORTS_DB_ID"
    memos: "REPLACE_ME_MEMOS_DB_ID"        # 원장 메모·대응기록 전용
    exams: "REPLACE_ME_EXAMS_DB_ID"        # 시험 결과·미응시 관리 전용

output:
  daily:
    mode: "html"             # html | notion | both
    path: "./reports_out/daily"
    public_url_base: ""      # Cloudflare Tunnel 공개 URL (예: https://webhook.demo.com/reports)
  weekly:
    mode: "html+notion"      # html | notion | html+notion
    require_approval: true   # Notion 아카이브 전 승인 필수
    path: "./reports_out/weekly"
  memo:
    mode: "notion"           # notion | off

anthropic:
  api_key: "sk-ant-REPLACE_ME"
  model: "claude-sonnet-4-6"
  report_model: "claude-opus-4-7"

llm:
  provider: "anthropic"        # anthropic | gemini — 분석/리포트/문구 생성 LLM 공급자
gemini:                        # provider=gemini 일 때 사용 (google-genai)
  api_key: "REPLACE_ME_GEMINI_KEY"
  model: "gemini-2.5-flash"
  report_model: "gemini-2.5-pro"

neis:
  api_key: "REPLACE_ME_NEIS_KEY"

notify:
  mode: "dry_run"
  provider: "aligo"
  aligo:
    api_key: "REPLACE_ME"
    user_id: "REPLACE_ME"
    sender: "01012345678"
    sender_key: "REPLACE_ME_ALIGO_SENDERKEY"                # 알리고 발신프로필 키
    template_code_missing_homework: "REPLACE_ME_TEMPLATE"   # 승인된 숙제 미제출 알림톡 템플릿 코드

webhook:
  host: "0.0.0.0"
  port: 8787
  dump_dir: "./samples/incoming"

reports:
  output_dir: "./reports_out"
  weekly_cron_day: "fri"
  weekly_cron_hour: 17
